# ---------------------------------------------------------------------------
# Focus Flow — environment variables
# ---------------------------------------------------------------------------
# Anything prefixed with VITE_ is bundled into the CLIENT and is PUBLIC.
# NEVER put a secret (Stripe secret key, service role key, webhook secret) in a
# VITE_ var. Server-only secrets are listed at the bottom and are configured
# with `supabase secrets set ...`, not here.
# ---------------------------------------------------------------------------

# --- Client (VITE_*, shipped to the browser) -------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id

# Stripe publishable key (public by design — pk_test_ / pk_live_).
VITE_STRIPE_PUBLIC_KEY=pk_test_xxx

# Optional: Stripe Price ids for the Plus plans. Public (just identifiers).
# When omitted, create-checkout falls back to the STRIPE_PRO_PRICE_ID secret.
VITE_STRIPE_PRO_PRICE_ID=price_xxx           # monthly
VITE_STRIPE_PRO_ANNUAL_PRICE_ID=price_xxx    # annual
VITE_STRIPE_LIFETIME_PRICE_ID=price_xxx      # one-time lifetime

# Optional client kill-switches / beta flags (set to 1 to enable). See docs/feature-flags.md
# VITE_KILL_SPOTIFY=1
# VITE_KILL_BINAURAL=1
# VITE_FLAG_AI_COACH=1

# ---------------------------------------------------------------------------
# --- Edge function secrets (SERVER ONLY — DO NOT prefix with VITE_) ---------
# These are NOT read from this file by the app. Set them on Supabase with:
#   supabase secrets set STRIPE_SECRET_KEY=sk_test_xxx \
#     STRIPE_WEBHOOK_SECRET=whsec_xxx \
#     STRIPE_PRO_PRICE_ID=price_xxx \
#     SUPABASE_SERVICE_ROLE_KEY=eyJ...
# (SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are auto-injected for deployed
#  functions; you only need to set SERVICE_ROLE_KEY for `supabase functions
#  serve` local runs.)
#
#   STRIPE_SECRET_KEY          Stripe secret key (sk_test_ / sk_live_)
#   STRIPE_WEBHOOK_SECRET      Signing secret for the webhook endpoint (whsec_)
#   STRIPE_PRO_PRICE_ID        Default Plus plan Price id used by create-checkout
#   STRIPE_PRO_ANNUAL_PRICE_ID Annual Plus Price id (allow-listed by create-checkout)
#   STRIPE_LIFETIME_PRICE_ID   Lifetime Price id — checkout uses one-time 'payment' mode
#   SUPABASE_SERVICE_ROLE_KEY  Service role key — bypasses RLS; webhook writes only
# ---------------------------------------------------------------------------
