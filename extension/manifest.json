{
  "manifest_version": 3,
  "name": "Focus Flow Blocker",
  "version": "0.4.0",
  "description": "Block distracting, gambling, adult and ad/pop-under sites by category, auto-close ad pop-up tabs, and hide sponsored posts on social networks — synced with your Focus Flow focus sessions.",
  "key": "",
  "permissions": ["declarativeNetRequest", "storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js", "type": "module" },
  "action": {
    "default_title": "Focus Flow Blocker",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:8080/*",
        "http://127.0.0.1:8080/*",
        "https://focusflow.app/*",
        "https://*.focusflow.app/*",
        "https://*.ngrok-free.dev/*",
        "https://*.ngrok-free.app/*",
        "https://*.ngrok.app/*",
        "https://*.trycloudflare.com/*"
      ],
      "js": ["bridge.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["adblock.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["adblock-main.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    },
    {
      "matches": [
        "https://*.instagram.com/*", "https://instagram.com/*",
        "https://*.facebook.com/*", "https://facebook.com/*",
        "https://*.twitter.com/*", "https://twitter.com/*",
        "https://x.com/*", "https://*.x.com/*",
        "https://*.youtube.com/*", "https://youtube.com/*",
        "https://*.reddit.com/*", "https://reddit.com/*",
        "https://*.linkedin.com/*", "https://linkedin.com/*",
        "https://*.tiktok.com/*", "https://tiktok.com/*"
      ],
      "js": ["social.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    { "resources": ["blocked.html"], "matches": ["<all_urls>"] }
  ]
}
