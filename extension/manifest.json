{
  "manifest_version": 3,
  "name": "Focus Flow Blocker",
  "version": "0.1.0",
  "description": "Block distracting, gambling and adult sites by category — synced with your Focus Flow focus sessions.",
  "permissions": ["declarativeNetRequest", "storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js", "type": "module" },
  "action": {
    "default_title": "Focus Flow Blocker",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:8080/*",
        "http://127.0.0.1:8080/*",
        "https://*.focusflow.app/*",
        "https://focus-flow*.vercel.app/*",
        "https://focus-flow*.netlify.app/*"
      ],
      "js": ["bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    { "resources": ["blocked.html"], "matches": ["<all_urls>"] }
  ]
}
